package app;

import parts.Engine;
import parts.Wheel;

public class Car {
    private Engine engine;
    private Wheel[] wheels;
    private String model;
    private String make;

    // Constructor
    public Car(Engine engine, Wheel[] wheels) {


    }

    // Getters
    public Engine getEngine() {
        return engine;
    }
    
    public Wheel[] getWheels() {
        return wheels;
    }
    
    // Setters
    public void setEngine(Engine engine) {
        if (engine == null) {
            throw new IllegalArgumentException("Engine cannot be null");
        }
        this.engine = engine;
    }
    
    public void setWheels(Wheel[] wheels) {
        if (wheels == null) {
            throw new IllegalArgumentException("Wheels array cannot be null");
        }
        this.wheels = wheels;
    }

    @Override
    public String toString() {
        StringBuilder WheelsStr = new StringBuilder();
        for (Wheel wheel : wheels) {
            WheelsStr.append(wheel.toString()).append(", ");
        }
        // Remove the trailing comma and space
        if (WheelsStr.length() > 0) {
            WheelsStr.setLength(WheelsStr.length() - 2);
        }
        return "Car{engine=" + engine.toString() + ", wheels=[" + WheelsStr.toString() + "]}";
}