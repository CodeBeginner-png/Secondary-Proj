package account;

public class CheckingAccount extends Account {
    private double transactionFee;
    private double overdraftLimit;

    public CheckingAccount(String owner, double initialBalance, double overdraftLimit) {
        super(owner, initialBalance);
        if (transactionFee < 0) {
            throw new IllegalArgumentException("Transaction fee cannot be negative.");
        }
        if (overdraftLimit < 0) {
            throw new IllegalArgumentException("Overdraft limit cannot be negative.");
        }
        this.transactionFee = transactionFee;
        this.overdraftLimit = overdraftLimit;
    }

    @Override
    public void withdraw(double amount) {
        if (amount <= 0) {
            throw new IllegalArgumentException("Withdrawal amount must be positive.");
        }
        double totalAmount = amount + transactionFee;
        double projected = balance - total;
        if (projected < -overdraftLimit) {
            throw new IllegalArgumentException("Overdraft limit exceeded.");
        }
        balance = projected;

    }
}